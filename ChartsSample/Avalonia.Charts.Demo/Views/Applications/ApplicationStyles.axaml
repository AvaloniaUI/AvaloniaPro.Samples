<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Spacing="10">
                <Border Classes="DashCard" Width="300" Height="200">
                    <TextBlock Text="Test Card" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!-- Theme-Aware Color Resources -->
    <Style>
        <Style.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Light">
                        <!-- Brushes -->
                        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F8FAFC" />
                        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
                        <SolidColorBrush x:Key="CardBackgroundDarkBrush" Color="#1A1A1A" />
                        <SolidColorBrush x:Key="SearchBarBackgroundBrush" Color="#F1F5F9" />
                        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
                        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B" />
                        <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8" />
                        <SolidColorBrush x:Key="BorderLightBrush" Color="#E2E8F0" />
                        <SolidColorBrush x:Key="BorderMediumBrush" Color="#CBD5E1" />
                        <SolidColorBrush x:Key="PrimaryGreenBrush" Color="#2D9A8F" />
                        <SolidColorBrush x:Key="PrimaryGreenLightBrush" Color="#E8F5F3" />
                        <SolidColorBrush x:Key="PrimaryGreenLighterBrush" Color="#F0FDFA" />
                        <LinearGradientBrush x:Key="BalanceSparklineFillBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Offset="0" Color="#302D9A8F" />
                            <GradientStop Offset="1" Color="#002D9A8F" />
                        </LinearGradientBrush>
                    </ResourceDictionary>
                    
                    <ResourceDictionary x:Key="Dark">
                        <!-- Brushes -->
                        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#0F172A" />
                        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E293B" />
                        <SolidColorBrush x:Key="CardBackgroundDarkBrush" Color="#0F172A" />
                        <SolidColorBrush x:Key="SearchBarBackgroundBrush" Color="#334155" />
                        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC" />
                        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CBD5E1" />
                        <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8" />
                        <SolidColorBrush x:Key="BorderLightBrush" Color="#334155" />
                        <SolidColorBrush x:Key="BorderMediumBrush" Color="#475569" />
                        <SolidColorBrush x:Key="PrimaryGreenBrush" Color="#34D399" />
                        <SolidColorBrush x:Key="PrimaryGreenLightBrush" Color="#2D9A8F" />
                        <SolidColorBrush x:Key="PrimaryGreenLighterBrush" Color="#065F46" />
                        <LinearGradientBrush x:Key="BalanceSparklineFillBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Offset="0" Color="#5034D399" />
                            <GradientStop Offset="1" Color="#0034D399" />
                        </LinearGradientBrush>
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>
            </ResourceDictionary>
            
            <!-- Static Colors (same in both themes) -->
            <Color x:Key="PositiveGreen">#22C55E</Color>
            <Color x:Key="NegativeRed">#EF4444</Color>
            <Color x:Key="WarningOrange">#F97316</Color>
            <Color x:Key="BitcoinOrange">#F7931A</Color>
            <Color x:Key="EthereumBlue">#627EEA</Color>
            <Color x:Key="XRPBlack">#23292F</Color>
            <Color x:Key="LitecoinBlue">#345D9D</Color>
            
        </Style.Resources>
    </Style>

    <!-- Dashboard Card Style -->
    <Style Selector="Border.DashCard">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderLightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="BoxShadow" Value="0 1 3 0 #0A000000" />
    </Style>

    <Style Selector="Border.BalanceCard">
        <Setter Property="Background" Value="{DynamicResource PrimaryGreenLighterBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryGreenLightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="28" />
        <Setter Property="BoxShadow" Value="0 4 12 0 #0D000000" />
    </Style>

    <Style Selector="Border.WalletCardGreen">
        <Setter Property="Background" Value="{DynamicResource PrimaryGreenBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BoxShadow" Value="0 8 20 0 #202D9A8F" />
    </Style>

    <Style Selector="Border.WalletCardGreen TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Border.WalletCardGreen TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Border.WalletCardWhite">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderLightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BoxShadow" Value="0 1 3 0 #0A000000" />
    </Style>

    <Style Selector="Border.WalletCardDark">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundDarkBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderLightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BoxShadow" Value="0 4 12 0 #40000000" />
    </Style>

    <Style Selector="Border.WalletCardDark TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Border.WalletCardDark TextBlock.Muted">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style Selector="Border.WalletCardDark TextBlock.MutedSmall">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <!-- Search Bar Style -->
    <Style Selector="Border.SearchBar">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource SearchBarBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Height" Value="40" />
    </Style>

    <Style Selector="Border.SearchBar:focus-within">
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryGreenBrush}" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
    </Style>

    <Style Selector="TextBox.SearchInput">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    
    <Style Selector="TextBox.SearchInput /template/ Border#PART_BorderElement">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="TextBox.SearchInput:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="TextBox.SearchInput:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ComboBox Style for Currency -->
    <Style Selector="ComboBox.CurrencyCombo">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMediumBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Height" Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>


    <!-- Time Period Button Style -->
    <Style Selector="Button.TimePeriod">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.TimePeriod:pointerover">
        <Setter Property="Background" Value="{DynamicResource SearchBarBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.TimePeriod.Selected">
        <Setter Property="Background" Value="{DynamicResource PrimaryGreenBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Section Header Style -->
    <Style Selector="TextBlock.SectionHeader">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.SectionHeaderMuted">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- KPI Value Styles -->
    <Style Selector="TextBlock.KpiValue">
        <Setter Property="FontSize" Value="42" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryGreenBrush}" />
    </Style>

    <Style Selector="TextBlock.KpiValueLarge">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.KpiLabel">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <!-- Muted Text Style -->
    <Style Selector="TextBlock.Muted">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="TextBlock.MutedSmall">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Change/Delta Styles -->
    <Style Selector="TextBlock.DeltaPositive">
        <Setter Property="Foreground" Value="#22C55E" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.DeltaNegative">
        <Setter Property="Foreground" Value="#EF4444" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Calendar Heatmap Styles -->
    <Style Selector="Border.CalendarDay">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Border.CalendarDay.Level0">
        <Setter Property="Background" Value="{DynamicResource PrimaryGreenLighterBrush}" />
    </Style>

    <Style Selector="Border.CalendarDay.Level1">
        <Setter Property="Background" Value="{DynamicResource PrimaryGreenLightBrush}" />
    </Style>

    <Style Selector="Border.CalendarDay.Level2">
        <Setter Property="Background" Value="{DynamicResource BorderMediumBrush}" />
    </Style>

    <Style Selector="Border.CalendarDay.Level3">
        <Setter Property="Background" Value="{DynamicResource PrimaryGreenBrush}" />
    </Style>

    <Style Selector="Border.CalendarDay.LevelHigh">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundDarkBrush}" />
    </Style>

    <Style Selector="TextBlock.CalendarDayText">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.CalendarDay.Level0 > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style Selector="Border.CalendarDay:not(.Level0) > TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Legend Styles -->
    <Style Selector="Border.LegendItem">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Link Style -->
    <Style Selector="TextBlock.Link">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryGreenBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="TextDecorations" Value="Underline" />
    </Style>

    <!-- Crypto Icon Container -->
    <Style Selector="Border.CryptoIcon">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Icon Button Style -->
    <Style Selector="Button.IconButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- Eye Icon Style -->
    <Style Selector="Path.EyeIcon">
        <Setter Property="Fill" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

</Styles>

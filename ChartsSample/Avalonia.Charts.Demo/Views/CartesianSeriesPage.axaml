<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:charts="https://avaloniaui.net/controls/charts"
             xmlns:vm="using:Avalonia.Charts.Demo.ViewModels.Charts"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="1600"
             x:CompileBindings="True" x:DataType="vm:CartesianSeriesViewModel"
             x:Class="Avalonia.Charts.Demo.Views.Charts.CartesianSeriesPage">
    <ScrollViewer>
        <StackPanel Spacing="20" Margin="20">
            <TextBlock Text="Explore the variety of Cartesian series types available for data visualization, from basic lines and bars to advanced financial and statistical plots." 
                       TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" />

            <!-- Line Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Line Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="LineChart" Title="Line Chart" Height="250" ShowLegend="True">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:LineSeries Title="2023" ItemsSource="{Binding LineSeries2023}" Stroke="DodgerBlue" StrokeThickness="2" MarkerSize="6" MarkerFill="DodgerBlue"  ShowMarkers="True"/>
                            <charts:LineSeries Title="2024" ItemsSource="{Binding LineSeries2024}" Stroke="Orange" StrokeThickness="2" MarkerSize="6" MarkerFill="Orange"  ShowMarkers="True"/>
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Connect data points with straight lines" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Bar Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Bar Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="BarChart" Title="Bar Chart" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:BarSeries Title="Sales" ItemsSource="{Binding BarSeriesData}" Fill="DodgerBlue" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Vertical bars representing data values" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Pictorial Bar Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Pictorial Bar Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="PictorialBarChart" Title="Vehicles in X City" Height="300" ShowLegend="True" LegendPosition="Right">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:PictorialBarSeries Title="2023" 
                                                       ItemsSource="{Binding PictorialBarData}" 
                                                       ValuePath="Value2023"
                                                       CategoryPath="Category"
                                                       Geometry="Icon"
                                                       RenderMode="Repeat"
                                                       SymbolSize="20"
                                                       SymbolSpacing="5"
                                                       Fill="#6495ED" />
                            <charts:PictorialBarSeries Title="2024" 
                                                       ItemsSource="{Binding PictorialBarData}" 
                                                       ValuePath="Value2024"
                                                       CategoryPath="Category"
                                                       Geometry="Icon"
                                                       RenderMode="Repeat"
                                                       SymbolSize="20"
                                                       SymbolSpacing="5"
                                                       Fill="#9ACD32" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Bars rendered with custom geometry from data item (repeated)" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Area Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Area Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="AreaChart" Title="Area Chart" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:AreaSeries Title="Revenue" ItemsSource="{Binding AreaSeriesData}" Fill="#7E4CAF50" Stroke="Green" StrokeThickness="2" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Filled area between line and axis" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Scatter Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Scatter Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="ScatterChart" Title="Scatter Plot" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:ScatterSeries Title="Data Points" ItemsSource="{Binding ScatterSeriesData}" Fill="Purple" MarkerSize="10" MarkerShape="Circle" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Individual data points plotted as markers" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Spline Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Spline Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="SplineChart" Title="Spline Chart" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:SplineSeries Title="Temperature" ItemsSource="{Binding SplineSeriesData}" Stroke="Crimson" StrokeThickness="3" MarkerSize="6" MarkerFill="White"  ShowMarkers="True"/>
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Smooth curved lines through data points" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Spline Area Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Spline Area Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="SplineAreaChart" Title="Spline Area Chart" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:SplineAreaSeries Title="Traffic" ItemsSource="{Binding SplineAreaSeriesData}" Fill="#7E2196F3" Stroke="DodgerBlue" StrokeThickness="2" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Filled area under smooth spline curve" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Step Line Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Step Line Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="StepLineChart" Title="Step Line Chart" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:StepLineSeries Title="Price" ItemsSource="{Binding StepLineSeriesData}" Stroke="Teal" StrokeThickness="2" MarkerSize="6"  ShowMarkers="True"/>
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Horizontal and vertical steps between points" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Stacked Bar Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Stacked Bar Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="StackedBarChart" Title="Stacked Bar Chart" Height="250" ShowLegend="True">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:StackedBarSeries Title="Product A" ItemsSource="{Binding StackedBarProductA}" Fill="DodgerBlue" />
                            <charts:StackedBarSeries Title="Product B" ItemsSource="{Binding StackedBarProductB}" Fill="Orange" />
                            <charts:StackedBarSeries Title="Product C" ItemsSource="{Binding StackedBarProductC}" Fill="Green" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Bars stacked on top of each other" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Stacked Area Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Stacked Area Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="StackedAreaChart" Title="Stacked Area Chart" Height="250" ShowLegend="True">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:StackedAreaSeries Title="Desktop" ItemsSource="{Binding StackedAreaDesktop}" Fill="#7E2196F3" Stroke="DodgerBlue" />
                            <charts:StackedAreaSeries Title="Mobile" ItemsSource="{Binding StackedAreaMobile}" Fill="#7E4CAF50" Stroke="Green" />
                            <charts:StackedAreaSeries Title="Tablet" ItemsSource="{Binding StackedAreaTablet}" Fill="#7EFF9800" Stroke="Orange" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Areas stacked on top of each other" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Range Area Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Range Area Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="RangeAreaChart" Title="Range Area Chart" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:AreaRangeSeries Title="Temperature Range" 
                                                      ItemsSource="{Binding RangeAreaData}"
                                                      LowPath="Low" HighPath="High" CategoryPath="Category"
                                                      Fill="#7EE91E63" Stroke="DeepPink" StrokeThickness="2" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Filled area between high and low values" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Variance Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Variance Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="VarianceChartSample" IsTooltipEnabled="True" Title="Monthly Performance vs Target" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:VarianceSeries Title="Variance from Target"
                                                   ItemsSource="{Binding VarianceData}"
                                                   CategoryPath="Month"
                                                   ValuePath="Variance"
                                                   Baseline="0"
                                                   PositiveBrush="Green"
                                                   NegativeBrush="Red"
                                                   BarWidth="0.7" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Positive and negative bars measured against a shared baseline" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Waterfall Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Waterfall Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="WaterfallChartSample" Title="Waterfall Chart" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:WaterfallSeries Title="Financial" 
                                                      ItemsSource="{Binding WaterfallData}"
                                                      ValuePath="Value" CategoryPath="Label"
                                                      PositiveBrush="Green" NegativeBrush="Red" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Shows cumulative effect of sequentially introduced values" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Box Plot Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Box Plot Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Name="BoxPlotSample" Title="Box Plot (Box and Whisker)" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:BoxPlotSeries Title="Distribution"
                                                    ItemsSource="{Binding BoxPlotData}"
                                                    CategoryPath="Category"
                                                    MinPath="Min" Q1Path="Q1" MedianPath="Median" Q3Path="Q3" MaxPath="Max"
                                                    Fill="#7E9C27B0" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Statistical distribution showing quartiles, median, and outliers" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Scatter Line Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Scatter Line Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Title="Measured Path" Height="260" ShowLegend="True">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:NumericalAxis Title="Distance" />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis Title="Value" />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:ScatterLineSeries Title="Telemetry"
                                                      ItemsSource="{Binding ScatterLineSeriesData}"
                                                      CategoryPath="X"
                                                      ValuePath="Value"
                                                      Stroke="#6D4C41"
                                                      StrokeThickness="2"
                                                      MarkerFill="#A1887F"
                                                      MarkerStroke="#6D4C41"
                                                      MarkerSize="9"
                                                      ShowMarkers="True"
                                                      ShowLines="True" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Scatter points connected in sampling order, useful for irregular numeric X values." Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Dot Plot Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Dot Plot Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Title="Daily Tickets" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:DotPlotSeries Title="Resolved"
                                                  ItemsSource="{Binding DotPlotData}"
                                                  CategoryPath="Category"
                                                  ValuePath="Value"
                                                  Fill="#5E35B1"
                                                  DotSize="11"
                                                  ShowConnectorLines="True"
                                                  ConnectorThickness="1.5" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Compact point-only distribution with optional connector lines between dots." Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Lollipop Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Lollipop Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Title="Channel Contribution" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:LollipopSeries Title="Contribution"
                                                   ItemsSource="{Binding LollipopData}"
                                                   CategoryPath="Category"
                                                   ValuePath="Value"
                                                   Fill="#00897B"
                                                   StemBrush="#004D40"
                                                   StemThickness="2.5"
                                                   MarkerShape="Circle"
                                                   MarkerSize="12" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Lollipop stems emphasize magnitude while keeping the endpoint marker prominent." Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Range Bar Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Range Bar Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Title="Estimated Delivery Window" Height="250">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:RangeBarSeries Title="Window"
                                                   ItemsSource="{Binding RangeBarData}"
                                                   CategoryPath="Category"
                                                   LowPath="Low"
                                                   HighPath="High"
                                                   Fill="#7E42A5F5"
                                                   Stroke="#1E88E5"
                                                   StrokeThickness="1.5"
                                                   BarWidth="0.62" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Floating bars visualize minimum-to-maximum intervals rather than a single point value." Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Stacked 100 Percent Bar Series -->
            <Border BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="2" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Stacked 100 Percent Bar Series" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentBrush}" />
                    <charts:CartesianChart Title="Traffic Mix by Quarter" Height="260" ShowLegend="True">
                        <charts:CartesianChart.HorizontalAxis>
                            <charts:CategoryAxis />
                        </charts:CartesianChart.HorizontalAxis>
                        <charts:CartesianChart.VerticalAxis>
                            <charts:NumericalAxis Minimum="0" Maximum="100" />
                        </charts:CartesianChart.VerticalAxis>
                        <charts:CartesianChart.Series>
                            <charts:Stacked100PercentBarSeries Title="Direct"
                                                               ItemsSource="{Binding Stacked100North}"
                                                               CategoryPath="Category"
                                                               ValuePath="Value"
                                                               Fill="#3949AB"
                                                               StackGroup="Mix" />
                            <charts:Stacked100PercentBarSeries Title="Organic"
                                                               ItemsSource="{Binding Stacked100South}"
                                                               CategoryPath="Category"
                                                               ValuePath="Value"
                                                               Fill="#43A047"
                                                               StackGroup="Mix" />
                            <charts:Stacked100PercentBarSeries Title="Partner"
                                                               ItemsSource="{Binding Stacked100West}"
                                                               CategoryPath="Category"
                                                               ValuePath="Value"
                                                               Fill="#FB8C00"
                                                               StackGroup="Mix" />
                        </charts:CartesianChart.Series>
                    </charts:CartesianChart>
                    <TextBlock Text="Normalizes each stack to 100% so changes in composition stand out across categories." Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="12" />
                </StackPanel>
            </Border>
        </StackPanel>

    </ScrollViewer>
</UserControl>
